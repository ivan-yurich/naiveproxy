#!/usr/bin/env bash
set -euo pipefail

CONF="/etc/unbound/unbound.conf.d/aurum-vpn.conf"
ENV_FILE="/etc/aurum-dns/aurum-dns.env"

source_env_if_safe() {
    [[ -f "$ENV_FILE" ]] || return 0

    local owner perms
    owner=$(stat -c '%U' "$ENV_FILE" 2>/dev/null || echo "unknown")
    perms=$(stat -c '%a' "$ENV_FILE" 2>/dev/null || echo "000")
    if [[ "$owner" != "root" ]]; then
        echo "Skip unsafe env file owner: $ENV_FILE belongs to $owner" >&2
        return 0
    fi
    if [[ "$perms" != "600" ]]; then
        chmod 600 "$ENV_FILE" 2>/dev/null || true
    fi

    # shellcheck disable=SC1090
    source "$ENV_FILE"
}

source_env_if_safe

echo "===== DNS (Unbound) status ====="
systemctl status unbound --no-pager || true
echo
echo "===== Port 53 listeners ====="
ss -H -lntup 2>/dev/null | awk '$5 ~ /:53$/ || $5 ~ /:53%/ {print}' || true
echo
echo "===== Config check ====="
if [[ -f "$CONF" ]]; then
    unbound-checkconf "$CONF" || true
else
    echo "Config not found: $CONF"
fi
echo
echo "===== Config summary ====="
echo "Gateway: ${AURUM_DNS_GATEWAY:-127.0.0.1}"
echo "CIDRs:   ${AURUM_DNS_CIDRS:-unknown}"
echo
echo "===== Last logs ====="
journalctl -u unbound -n 40 --no-pager || true
